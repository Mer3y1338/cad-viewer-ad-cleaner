<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/app_color_main_black1" />
            <stroke android:width="0.0dp" android:color="#33ffffff" />
            <corners android:topLeftRadius="5.0dp" android:bottomLeftRadius="5.0dp" />
        </shape>
    </item>
    <item android:state_checked="true">
        <shape>
            <solid android:color="@color/app_color_main_black1" />
            <stroke android:width="0.0dp" android:color="#33ffffff" />
            <corners android:topLeftRadius="5.0dp" android:bottomLeftRadius="5.0dp" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape>
            <solid android:color="@color/app_color_main_black1" />
            <stroke android:width="0.0dp" android:color="#33ffffff" />
            <corners android:topLeftRadius="5.0dp" android:bottomLeftRadius="5.0dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="#00000000" />
            <stroke android:width="0.0dp" android:color="#33ffffff" />
            <corners android:radius="5.0dp" />
        </shape>
    </item>
</selector>
