<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <corners android:topRightRadius="25.0dp" android:bottomRightRadius="25.0dp" />
            <solid android:color="#ff00" />
        </shape>
    </item>
    <item android:left="1.0dp" android:top="1.0dp" android:right="1.0dp" android:bottom="1.0dp">
        <selector>
            <item android:state_selected="true">
                <shape>
                    <corners android:topRightRadius="25.0dp" android:bottomRightRadius="25.0dp" />
                    <solid android:color="#ffff00" />
                </shape>
            </item>
            <item>
                <shape>
                    <corners android:topRightRadius="25.0dp" android:bottomRightRadius="25.0dp" />
                    <solid android:color="#ffffff" />
                </shape>
            </item>
        </selector>
    </item>
</layer-list>
