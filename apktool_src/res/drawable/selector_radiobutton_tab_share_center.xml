<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/gstar_bg_color_blue" />
            <stroke android:width="0.0dp" android:color="@color/gstar_bg_color_gray2" />
            <corners android:topLeftRadius="0.0dp" android:topRightRadius="0.0dp" android:bottomLeftRadius="0.0dp" android:bottomRightRadius="0.0dp" />
        </shape>
    </item>
    <item android:state_checked="true">
        <shape>
            <solid android:color="@color/gstar_bg_color_blue" />
            <stroke android:width="0.0dp" android:color="@color/gstar_bg_color_gray2" />
            <corners android:topLeftRadius="0.0dp" android:topRightRadius="0.0dp" android:bottomLeftRadius="0.0dp" android:bottomRightRadius="0.0dp" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape>
            <solid android:color="@color/gstar_bg_color_blue" />
            <stroke android:width="0.0dp" android:color="@color/gstar_bg_color_gray2" />
            <corners android:topLeftRadius="0.0dp" android:topRightRadius="0.0dp" android:bottomLeftRadius="0.0dp" android:bottomRightRadius="0.0dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/gstar_bg_color_white" />
            <stroke android:width="0.5dp" android:color="@color/gstar_bg_color_black_divider1" />
            <corners android:topLeftRadius="0.0dp" android:topRightRadius="0.0dp" android:bottomLeftRadius="0.0dp" android:bottomRightRadius="0.0dp" />
        </shape>
    </item>
</selector>
