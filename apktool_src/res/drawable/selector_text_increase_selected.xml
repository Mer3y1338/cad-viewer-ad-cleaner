<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/dialog_new_bg_main_black2" />
            <stroke android:width="1.0dp" android:color="@color/gstar_text_color_blue" />
            <corners android:radius="5.0dp" />
        </shape>
    </item>
    <item android:state_checked="true">
        <shape>
            <solid android:color="@color/dialog_new_bg_main_black2" />
            <stroke android:width="1.0dp" android:color="@color/gstar_text_color_blue" />
            <corners android:radius="5.0dp" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape>
            <solid android:color="@color/dialog_new_bg_main_black2" />
            <stroke android:width="1.0dp" android:color="@color/gstar_text_color_blue" />
            <corners android:radius="5.0dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/dialog_new_bg_main_black2" />
            <stroke android:width="1.0dp" android:color="@color/dialog_new_bg_main_black2" />
            <corners android:radius="5.0dp" />
        </shape>
    </item>
</selector>
