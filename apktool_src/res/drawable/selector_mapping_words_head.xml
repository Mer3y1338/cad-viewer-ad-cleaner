<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <layer-list>
            <item android:gravity="bottom">
                <shape android:shape="rectangle">
                    <size android:height="11.0dp" android:width="45.0dp" />
                    <solid android:color="#ff3c3c3c" />
                    <corners android:bottomLeftRadius="8.0dp" android:bottomRightRadius="8.0dp" />
                </shape>
            </item>
            <item>
                <bitmap android:gravity="center|bottom" android:src="@drawable/arrow_triangle_up" />
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item android:gravity="bottom">
                <shape android:shape="rectangle">
                    <size android:height="11.0dp" android:width="45.0dp" />
                    <solid android:color="#ff3c3c3c" />
                    <corners android:bottomLeftRadius="8.0dp" android:bottomRightRadius="8.0dp" />
                </shape>
            </item>
            <item>
                <bitmap android:gravity="center|bottom" android:src="@drawable/arrow_triangle_down" />
            </item>
        </layer-list>
    </item>
</selector>
