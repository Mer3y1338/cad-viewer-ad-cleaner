        <shape android:shape="rectangle">
            <corners android:radius="5.0dp" />
            <solid android:color="#fffffdf5" />
            <stroke android:width="1.0dp" android:color="#ffffddc1" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <corners android:radius="5.0dp" />
            <solid android:color="#fffffdf5" />
            <stroke android:width="1.0dp" android:color="#ffffddc1" />
